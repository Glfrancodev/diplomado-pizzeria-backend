# Variables para correr el backend EN LOCAL (DynamoDB Local + NATS de docker-compose).
# Copialo a .env:  cp .env.example .env   (el .env real está en .gitignore)
#
# En AWS estas variables las inyecta la infra (task definition); ahí NO se usa
# DYNAMO_ENDPOINT (se usa el DynamoDB real + el IAM role).

# Región (en local da igual el valor; DynamoDB Local lo ignora con -sharedDb)
AWS_REGION=us-east-1

# Apunta al DynamoDB Local. Su PRESENCIA es lo que activa el modo local en el código.
DYNAMO_ENDPOINT=http://localhost:8000

# Broker NATS local
NATS_URL=nats://localhost:4222

# Puerto HTTP de orders
ORDERS_HTTP_PORT=3000

# Origen permitido por CORS (la URL del frontend). En la nube la inyecta la infra
# (task definition de orders) con la URL real del S3/CloudFront. En local podés
# dejarla vacía (cae a '*') o apuntarla al dev server del frontend (ej: http://localhost:5173).
FRONTEND_URL=

# Nombres de las 4 tablas (mismos que crea el seed y que usaría la infra)
TABLE_PEDIDOS=pizzeria-pedidos
TABLE_PRODUCTOS=pizzeria-productos
TABLE_INGREDIENTES=pizzeria-ingredientes
TABLE_REPARTIDORES=pizzeria-repartidores
